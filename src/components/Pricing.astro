---
---

<section class="section" id="pricing">
  <div class="section-label">// Simple pricing</div>
  <h2>PICK YOUR<br />MEME LEVEL.</h2>
  <div class="pricing-grid fade-in">
    <div class="price-card">
      <div class="price-tier">Starter</div>
      <div class="price-amount">$29</div>
      <div class="price-period">/month &middot; billed monthly</div>
      <ul class="price-features">
        <li>5 image memes per week</li>
        <li>1 review source connected</li>
        <li>Platform captions included</li>
        <li>Weekly newsletter draft</li>
        <li>ZIP download</li>
      </ul>
      <a href="#" class="btn-plan">Get started &rarr;</a>
    </div>
    <div class="price-card featured">
      <div class="price-badge">Most popular</div>
      <div class="price-tier">Growth</div>
      <div class="price-amount">$79</div>
      <div class="price-period">/month &middot; billed monthly</div>
      <ul class="price-features">
        <li>5 image + 2 video memes/week</li>
        <li>3 review sources connected</li>
        <li>Platform captions included</li>
        <li>Weekly newsletter — ready to send</li>
        <li>Notion content calendar push</li>
        <li>Regenerate &amp; edit memes</li>
      </ul>
      <a href="#" class="btn-plan">Get started &rarr;</a>
    </div>
    <div class="price-card">
      <div class="price-tier">Agency</div>
      <div class="price-amount">$249</div>
      <div class="price-period">/month &middot; billed monthly</div>
      <ul class="price-features">
        <li>Daily meme generation</li>
        <li>Up to 5 brands / product lines</li>
        <li>Video memes included</li>
        <li>White-label newsletter</li>
        <li>Buffer/Hootsuite scheduling</li>
        <li>Dedicated Slack support</li>
      </ul>
      <a href="#" class="btn-plan">Talk to us &rarr;</a>
    </div>
  </div>
</section>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 48px;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
      margin-top: 64px;
    }
  }

  @media (min-width: 1024px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .price-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  @media (min-width: 768px) {
    .price-card {
      padding: 40px 32px;
    }
  }

  .price-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }

  .price-card.featured {
    background: var(--black);
    color: var(--cream);
    border-color: var(--orange);
    transform: translateY(-8px);
    box-shadow: var(--shadow-offset-orange);
  }

  .price-card.featured:hover {
    transform: translateY(-12px);
    box-shadow: 8px 8px 0 var(--orange);
  }

  .price-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: var(--white);
    padding: 4px 14px;
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  .price-tier {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--gray);
    margin-bottom: 12px;
  }

  .price-amount {
    font-family: var(--font-heading);
    font-size: 56px;
    line-height: 1;
    letter-spacing: 1px;
    color: var(--black);
  }

  @media (min-width: 768px) {
    .price-amount {
      font-size: 64px;
    }
  }

  .price-card.featured .price-amount {
    color: var(--cream);
  }

  .price-period {
    font-size: 14px;
    color: var(--gray);
    margin-bottom: 28px;
  }

  .price-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .price-features li {
    font-size: 14px;
    color: var(--text-dark);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .price-card.featured .price-features li {
    color: #ccc;
  }

  .price-features li::before {
    content: '\2713';
    color: var(--green);
    font-weight: 700;
    font-size: 15px;
    flex-shrink: 0;
  }

  .btn-plan {
    display: block;
    width: 100%;
    padding: 14px;
    border-radius: 6px;
    text-align: center;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid var(--black);
    background: transparent;
    color: var(--black);
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn-plan:hover {
    background: var(--black);
    color: var(--cream);
  }

  .price-card.featured .btn-plan {
    background: var(--orange);
    color: var(--white);
    border-color: var(--orange);
  }

  .price-card.featured .btn-plan:hover {
    background: var(--orange-hover);
    border-color: var(--orange-hover);
    color: var(--white);
  }
</style>
