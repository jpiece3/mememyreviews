<style>
  .ticker-wrap {
    background: var(--black);
    padding: 14px 0;
    overflow: hidden;
    position: relative;
  }

  .ticker {
    display: flex;
    gap: 0;
    animation: ticker 30s linear infinite;
    width: max-content;
  }

  .ticker-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 32px;
    font-family: var(--font-heading);
    font-size: 16px;
    letter-spacing: 2px;
    color: var(--cream);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .ticker-item {
      font-size: 18px;
    }
  }

  .dot {
    color: var(--orange);
    font-size: 20px;
  }

  @media (min-width: 768px) {
    .dot {
      font-size: 24px;
    }
  }
</style>
