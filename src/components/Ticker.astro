    <div class="ticker-item"><span class="dot">&#9679;</span> MEMES FROM REVIEWS</div>
    <div class="ticker-item"><span class="dot">&#9679;</span> WEEKLY NEWSLETTER</div>
    <div class="ticker-item"><span class="dot">&#9679;</span> ZERO EFFORT</div>
    <div class="ticker-item"><span class="dot">&#9679;</span> AUTO-GENERATED CAPTIONS</div>
