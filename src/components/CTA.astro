<section class="cta-section">
  <div class="cta-bg-text">MEME</div>
  <div class="cta-content">
    <h2>STOP LEAVING<br />YOUR REVIEWS<br />UNBOTHERED.</h2>
    <p>Your customers are writing comedy gold. MemeMyReviews turns it into content that spreads. Start free — no credit card required.</p>
    <a href="#waitlist" class="btn-primary">Start your free trial &rarr;</a>
    <p class="cta-note">14-day free trial &middot; Cancel anytime &middot; Setup takes 3 minutes</p>
  </div>
</section>

<style>
  .cta-section {
    background: var(--black);
    padding: 80px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .cta-section {
      padding: 120px 48px;
    }
  }

  .cta-bg-text {
    font-family: var(--font-heading);
    font-size: 200px;
    letter-spacing: 20px;
    color: rgba(255, 255, 255, 0.03);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .cta-bg-text {
      font-size: 300px;
    }
  }

  .cta-content {
    position: relative;
  }

  .cta-section h2 {
    color: var(--cream);
    margin-bottom: 20px;
  }

  .cta-section p {
    color: #888;
    font-size: 16px;
    max-width: 480px;
    margin: 0 auto 40px;
    line-height: 1.65;
  }

  @media (min-width: 768px) {
    .cta-section p {
      font-size: 18px;
    }
  }

  .cta-section .btn-primary {
    font-size: 15px;
    padding: 16px 36px;
  }

  @media (min-width: 768px) {
    .cta-section .btn-primary {
      font-size: 16px;
      padding: 18px 40px;
    }
  }

  .cta-note {
    margin-top: 20px;
    font-size: 13px !important;
    color: #555 !important;
  }
</style>
