---
---

<section class="waitlist-section" id="waitlist">
  <div class="waitlist-inner">
    <div class="section-label">// Early access</div>
    <h2>GET IN EARLY.<br />BE FIRST TO<br />MEME YOUR REVIEWS.</h2>
    <p class="waitlist-sub">We're launching soon. Drop your email and we'll let you know the second it's live.</p>

    <form class="waitlist-form" id="waitlist-form">
      <input type="hidden" name="plan" id="waitlist-plan" value="" />
      <div class="waitlist-input-row">
        <input
          type="email"
          name="email"
          placeholder="you@company.com"
          required
          class="waitlist-input"
        />
        <button type="submit" class="waitlist-btn">
          Join the waitlist &rarr;
        </button>
      </div>
      <div class="waitlist-message" id="waitlist-message"></div>
    </form>

    <div class="waitlist-note">No spam. Just a heads-up when we launch.</div>
  </div>
</section>

<style>
  .waitlist-section {
    padding: 80px 24px;
    background: var(--white);
    border-top: 1.5px solid var(--border);
    border-bottom: 1.5px solid var(--border);
  }

  @media (min-width: 768px) {
    .waitlist-section {
      padding: 100px 48px;
    }
  }

  .waitlist-inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .waitlist-sub {
    font-size: 16px;
    color: var(--gray);
    margin-top: 16px;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .waitlist-sub {
      font-size: 17px;
    }
  }

  .waitlist-form {
    width: 100%;
  }

  .waitlist-input-row {
    display: flex;
    gap: 8px;
    flex-direction: column;
  }

  @media (min-width: 480px) {
    .waitlist-input-row {
      flex-direction: row;
    }
  }

  .waitlist-input {
    flex: 1;
    padding: 14px 18px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--black);
    background: var(--cream);
    transition: border-color 0.15s;
  }

  .waitlist-input:focus {
    outline: none;
    border-color: var(--orange);
  }

  .waitlist-input::placeholder {
    color: #aaa;
  }

  .waitlist-btn {
    padding: 14px 28px;
    background: var(--orange);
    color: var(--white);
    border: none;
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: var(--shadow-offset);
    white-space: nowrap;
  }

  .waitlist-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-offset-lg);
  }

  .waitlist-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .waitlist-message {
    margin-top: 12px;
    font-size: 14px;
    min-height: 20px;
  }

  .waitlist-message.success {
    color: #0d9e4f;
    font-weight: 500;
  }

  .waitlist-message.error {
    color: #dc2626;
  }

  .waitlist-note {
    margin-top: 16px;
    font-size: 12px;
    color: var(--gray);
    font-family: var(--font-mono);
  }
</style>

<script is:inline>
  const form = document.getElementById('waitlist-form');
  const msg = document.getElementById('waitlist-message');
  const planInput = document.getElementById('waitlist-plan');

  // Capture plan from URL hash (e.g. #waitlist?plan=growth)
  function getPlanFromHash() {
    const hash = window.location.hash;
    const match = hash.match(/plan=(\w+)/);
    return match ? match[1] : '';
  }

  // Update plan when hash changes (user clicks pricing button)
  window.addEventListener('hashchange', () => {
    planInput.value = getPlanFromHash();
  });
  planInput.value = getPlanFromHash();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = form.querySelector('input[type="email"]').value;
    const plan = planInput.value;
    const btn = form.querySelector('button');

    btn.disabled = true;
    btn.textContent = 'Joining...';
    msg.textContent = '';
    msg.className = 'waitlist-message';

    try {
      const res = await fetch(
        'https://nnxbgderdyjanzwgabxl.supabase.co/rest/v1/waitlist',
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            apikey: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5ueGJnZGVyZHlqYW56d2dhYnhsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkxODA3MzgsImV4cCI6MjA4NDc1NjczOH0.jpjZ_gH1-2GZgyhXPRzPrZzWWnJtAVgU4yui4KM6wZ8',
            Prefer: 'return=minimal',
          },
          body: JSON.stringify({ email, plan: plan || null }),
        }
      );

      if (res.ok) {
        msg.textContent = "You're on the list! We'll email you when it's live.";
        msg.className = 'waitlist-message success';
        form.querySelector('input[type="email"]').value = '';
        btn.textContent = 'You\'re in! ✓';
      } else {
        throw new Error('Failed');
      }
    } catch {
      msg.textContent = 'Something went wrong. Try again?';
      msg.className = 'waitlist-message error';
      btn.disabled = false;
      btn.textContent = 'Join the waitlist →';
    }
  });
</script>
